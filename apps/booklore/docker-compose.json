{
  "schemaVersion": 2,
  "services": [
    {
      "name": "booklore",
      "image": "booklore/booklore:v2.2.0",
      "isMain": true,
      "internalPort": "6060",
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/app/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/books",
          "containerPath": "/books"
        },
        {
          "hostPath": "${APP_DATA_DIR}/bookdrop",
          "containerPath": "/bookdrop"
        }
      ],
      "environment": [
        {
          "key": "USER_ID",
          "value": "1000"
        },
        {
          "key": "GROUP_ID",
          "value": "1000"
        },
        {
          "key": "TZ",
          "value": "Etc/UTC"
        },
        {
          "key": "DATABASE_URL",
          "value": "jdbc:mariadb://booklore_db:3306/booklore"
        },
        {
          "key": "DATABASE_USERNAME",
          "value": "booklore"
        },
        {
          "key": "DATABASE_PASSWORD",
          "value": "${BOOKLORE_DATABASE_PASSWORD}"
        },
        {
          "key": "BOOKLORE_PORT",
          "value": "6060"
        }
      ]
    },
    {
      "name": "booklore_db",
      "image": "lscr.io/linuxserver/mariadb:11.4.9",
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/mariadb/config",
          "containerPath": "/config"
        }
      ],
      "environment": [
        {
          "key": "PUID",
          "value": "1000"
        },
        {
          "key": "PGID",
          "value": "1000"
        },
        {
          "key": "TZ",
          "value": "Etc/UTC"
        },
        {
          "key": "MYSQL_ROOT_PASSWORD",
          "value": "${BOOKLORE_DATABASE_ROOT_PASSWORD}"
        },
        {
          "key": "MYSQL_DATABASE",
          "value": "booklore"
        },
        {
          "key": "MYSQL_USER",
          "value": "booklore"
        },
        {
          "key": "MYSQL_PASSWORD",
          "value": "${BOOKLORE_DATABASE_PASSWORD}"
        }
      ]
    }
  ]
}
